---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Teaching" description="Teaching experience of Christina M. Bradley">
  <div class="teaching-page">
    <h1>Teaching</h1>

    <!-- ── Sole Instructor ── -->
    <h2>Sole Instructor</h2>

    <div class="course-list">
      <div class="course">
        <div class="course-header">
          <div>
            <h3>Weekend MBA 612 — Bargaining &amp; Influence Skills: Negotiating Strategy in a Global Economy</h3>
            <p class="course-meta">Spring/Summer 2023, 2024, 2025 &bull; University of Michigan, Stephen M. Ross School of Business</p>
          </div>
        </div>
        <div class="course-details">
          <div class="detail-row">
            <span class="detail-label">Enrollment</span>
            <span>32 students (2023) &bull; 35 students (2024) &bull; 30 students (2025)</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Ratings</span>
            <span>
              <span class="rating">4.6/5.0</span> (2023) &bull;
              <span class="rating">4.7/5.0</span> (2024) &bull;
              <span class="rating">4.7/5.0</span> (2025)
            </span>
          </div>
        </div>
      </div>

      <div class="course">
        <div class="course-header">
          <div>
            <h3>MO 300 — Behavioral Theories in Management</h3>
            <p class="course-meta">Fall 2021 &bull; University of Michigan, Stephen M. Ross School of Business</p>
          </div>
        </div>
        <div class="course-details">
          <div class="detail-row">
            <span class="detail-label">Enrollment</span>
            <span>78 undergraduate students</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Rating</span>
            <span><span class="rating">4.9/5.0</span></span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Award</span>
            <span>Thomas W. Leabo Memorial Award for Academic and Teaching Excellence, Ross School of Business 2020–21 <em>(recognizes top 1–2 student instructors at Ross)</em></span>
          </div>
        </div>
      </div>
    </div>

    <!-- ── Teaching Assistantships ── -->
    <h2>Teaching Assistantships</h2>
    <ul class="ta-list">
      <li>
        <span class="ta-year">2022–2024</span>
        <div>
          <strong>Negotiation Strategy</strong> — Full-time MBA<br />
          <span class="ta-instructor">with Professor Jeffrey Sanchez-Burks</span>
        </div>
      </li>
      <li>
        <span class="ta-year">2020–2024</span>
        <div>
          <strong>Leading Organizational Change</strong> — Executive MBA<br />
          <span class="ta-instructor">with Professor Jeffrey Sanchez-Burks</span>
        </div>
      </li>
      <li>
        <span class="ta-year">2019</span>
        <div>
          <strong>Leading People and Organizations</strong> — Full-time MBA<br />
          <span class="ta-instructor">with Professor Dave Mayer</span>
        </div>
      </li>
      <li>
        <span class="ta-year">2019</span>
        <div>
          <strong>Human Behavior and Organizations: Managing for Excellence in Work Organizations</strong> — Full-time MBA<br />
          <span class="ta-instructor">with Professor Wayne Baker</span>
        </div>
      </li>
    </ul>

    <!-- ── Other Invited Talks ── -->
    <h2>Other Invited Talks</h2>
    <ul class="ta-list">
      <li>
        <span class="ta-year">2025</span>
        <span>Leadership Development Program, Negotiations Training — University of Michigan, Department of Radiology</span>
      </li>
      <li>
        <span class="ta-year">2025</span>
        <span>Michigan ITS Internship Program — Invited Guest Lecture</span>
      </li>
      <li>
        <span class="ta-year">2024</span>
        <span>University of Michigan Medical School, Teamwork in Healthcare — Invited Guest Lecture</span>
      </li>
      <li>
        <span class="ta-year">2024</span>
        <span>University of Michigan, Foundations in Leadership Class — Invited Guest Lecture</span>
      </li>
      <li>
        <span class="ta-year">2023</span>
        <span>University of Michigan, Center for Positive Organizations, Adderley Research Incubator</span>
      </li>
      <li>
        <span class="ta-year">2023</span>
        <span>University of California, Riverside, Management Department — Department Seminar</span>
      </li>
      <li>
        <span class="ta-year">2022</span>
        <span>Duke University, Management Department — Department Seminar</span>
      </li>
      <li>
        <span class="ta-year">2022</span>
        <span>International Association for Conflict Management (IACM) — Virtual Seminar Series</span>
      </li>
      <li>
        <span class="ta-year">2022</span>
        <span>University of Michigan Ross, Management &amp; Organization — Department Seminar</span>
      </li>
      <li>
        <span class="ta-year">2021</span>
        <span>University of Michigan, Social Psychology Department — Department Seminar</span>
      </li>
      <li>
        <span class="ta-year">2021</span>
        <span>Rotterdam School of Management, Management Department — Research Presentation</span>
      </li>
      <li>
        <span class="ta-year">2020</span>
        <span>University of Michigan, Self-Control Lab led by Ethan Kross — Research Presentation</span>
      </li>
      <li>
        <span class="ta-year">2020</span>
        <span>University of Michigan Ross, Management &amp; Organization — Department Seminar</span>
      </li>
      <li>
        <span class="ta-year">2020</span>
        <span>University of Michigan Ross, Center for Positive Organizations — Invited Guest Lecture</span>
      </li>
    </ul>

    <!-- ── Student Feedback ── -->
    <h2>Student Feedback</h2>
    <div class="quotes">
      <blockquote>
        "Christina is a WONDERFUL instructor — bright and encouraging with exceptional facilitation skills."
      </blockquote>
      <blockquote>
        "She is incredibly responsive to student feedback and creates an engaging and inclusive learning environment."
      </blockquote>
    </div>
  </div>
</Layout>

<style>
  .teaching-page {
    max-width: 760px;
  }

  h1 {
    margin-bottom: 1.1rem;
  }

  /* ── Courses ── */
  .course-list {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .course {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-card);
  }

  .course-header {
    padding: 1.1rem 1.25rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: #f7f6f2;
  }

  .course-header h3 {
    font-size: 1.05rem;
    color: var(--navy);
    margin-bottom: 0.2rem;
  }

  .course-meta {
    font-size: 0.85rem;
    color: var(--text-light);
    margin: 0;
  }

  .course-details {
    padding: 0.9rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-row {
    display: flex;
    gap: 1rem;
    font-size: 0.92rem;
    align-items: baseline;
  }

  .detail-label {
    font-weight: 500;
    color: var(--text-light);
    min-width: 6rem;
    flex-shrink: 0;
  }

  .rating {
    font-weight: 600;
    color: var(--navy);
  }

  /* ── TA list ── */
  .ta-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .ta-list li {
    display: flex;
    gap: 1.25rem;
    font-size: 0.95rem;
    align-items: baseline;
  }

  .ta-year {
    color: var(--accent);
    font-weight: 500;
    flex-shrink: 0;
    width: 5.5rem;
  }

  .ta-instructor {
    font-size: 0.88rem;
    color: var(--text-light);
  }

  /* ── Quotes ── */
  .quotes {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  blockquote {
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--text-light);
    border-left: 3px solid var(--accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 0;
  }
</style>
