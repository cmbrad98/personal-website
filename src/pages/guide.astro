---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Emotion-Response Guide"
  description="An interactive guide to help you navigate how to respond to emotions at work, based on peer-reviewed research by Bradley, Greer, Trinh & Sanchez-Burks (2024)."
>
  <div class="guide-intro">
    <p class="section-label">Interactive Tool</p>
    <h1>Emotion-Response Guide</h1>
    <p class="guide-subtitle">How Should You Respond to Someone's Emotions at Work?</p>
    <p class="guide-intro-text">
      Use this interactive guide to identify which emotion-response strategies are most likely
      to lead to positive outcomes in your specific situation at work. Based on research by
      Bradley, Greer, Trinh &amp; Sanchez-Burks (2024), <em>Academy of Management Annals, 18</em>(1), 3–43.
    </p>
  </div>

  <div class="guide-frame-wrapper">
    <iframe
      id="guide-iframe"
      src="/emotion-response-guide.html"
      frameborder="0"
      scrolling="no"
      title="Emotion-Response Interactive Guide"
    ></iframe>
  </div>
</Layout>

<style>
  .guide-intro {
    margin-bottom: 2rem;
  }

  .guide-intro h1 {
    margin-top: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .guide-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-style: italic;
    color: var(--text-light);
    margin-bottom: 0.75rem;
  }

  .guide-intro-text {
    color: var(--text-light);
    font-size: 0.95rem;
    max-width: 600px;
    line-height: 1.65;
  }

  /* Break out of main's side padding so the guide runs full-width */
  .guide-frame-wrapper {
    margin: 0 -1.5rem -4rem;
  }

  #guide-iframe {
    width: 100%;
    border: none;
    display: block;
    min-height: 700px;
  }

  @media (max-width: 600px) {
    .guide-frame-wrapper {
      margin: 0 -1.25rem -3rem;
    }
  }
</style>

<script>
  const iframe = document.getElementById('guide-iframe') as HTMLIFrameElement;

  window.addEventListener('message', (e: MessageEvent) => {
    if (!e.data || typeof e.data !== 'object') return;

    // Resize iframe to match guide content height
    if (e.data.type === 'guide-resize') {
      iframe.style.height = (e.data.height + 24) + 'px';
    }

    // Scroll parent page to top of iframe when guide navigates
    if (e.data.type === 'guide-scroll-top') {
      const iframeTop = iframe.getBoundingClientRect().top + window.scrollY;
      window.scrollTo({ top: Math.max(0, iframeTop - 80), behavior: 'smooth' });
    }
  });
</script>
